<script>
  // Scroll animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.12 });

  document.querySelectorAll('.value-card, .approach-step, .approach-aside').forEach(el => observer.observe(el));

  // Why card animation
  const whyObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.2 });
  const whyCard = document.getElementById('why-card');
  if (whyCard) whyObserver.observe(whyCard);

  // Staggered value cards
  document.querySelectorAll('.value-card').forEach((card, i) => {
    card.style.transitionDelay = `${i * 0.1}s`;
  });

  // Staggered approach steps
  document.querySelectorAll('.approach-step').forEach((step, i) => {
    step.style.transitionDelay = `${i * 0.12}s`;
  });
</script>
</body>
</html>
